@using Shop_Klimov.Data.ViewModell;

@model VMItems

@{
    Layout = "_Layout";
}

<div class="selection" >
    <select id="categorySelect" onchange="SelectCategory(this)" style="height: 30px">
        <option value="0">Выбрать...</option>
        @{
            foreach (var Category in Model.Categories)
            {
                if (Category.Id == Model.SelectCategory)
                {
                    <option selected="selected" value="@Category.Id">@Category.Name</option>
                }
                else
                {
                    <option value="@Category.Id">@Category.Name</option>
                }
            }
        }
    </select>
    <p>Сортировка по цене:</p>
    <button onclick="sortAsc()">От меньшей к большей</button>
    <button onclick="sortDesc()">От большей к меньшей</button>
    <script>
        function SelectCategory(sender) {
            window.location = "/Items/List?id=" + sender.value;
        }

        function sortAsc() {
            var select = document.getElementById(`categorySelect`);
            window.location = "/Items/List?id=" + select.value + "&sort=asc";
        }

        function sortDesc() {
            var select = document.getElementById(`categorySelect`);
            window.location = "/Items/List?id=" + select.value + "&sort=desc";
        }
    </script>
</div>

<h2>Все предметы</h2>

@{
    foreach (var item in Model.Items)
    {
        if (Model.SelectCategory == 0 || item.Category.Id == Model.SelectCategory)
        {
            <div class="item">
                <img src="@item.Img" />
                <div class="data">
                    <h3>Модель: @item.Name</h3>
                    <div>Цена: @item.Price.ToString("c")</div>
                    <div>Категория: @item.Category.Name</div>
                    <div>Описание: @item.Description</div>
                </div>
                <div class="DelEdit">
                    <form method="post" action="/Items/Delete">
                        <input type="hidden" name="id" value="@item.Id" />
                        <input type="submit" value="Удалить" />
                    </form>

                    <form method="get" action="/Items/Update">
                        <input type="hidden" name="id" value="@item.Id" />
                        <input type="submit" value="Изменить" />
                    </form>
                </div>
            </div>
        }
    }
}
